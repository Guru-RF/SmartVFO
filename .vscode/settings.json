{
    "C_Cpp.default.configurationProvider": "platformio.platformio-ide",
    "editor.formatOnSave": true,
    "files.associations": {
        "*.h": "c",
        "*.cpp": "cpp"
    },
    "files.exclude": {
        "**/.git": true,
        "**/.pio": true,
        "**/node_modules": true
    },
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true
}
